{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "objectWrap": "preserve",
  "sortPackageJson": false,
  "overrides": [
    {
      "files": ["src/**/*"],
      "options": {
        "printWidth": 80
      }
    }
  ]
}
